# Local-only folders (per README) -- these hold per-run, per-user files
# and should never be committed to the shared repo. Each folder's own
# README.md stays tracked; everything else in it is ignored.

# 1 inbound/ -- drop zone for source files
1 inbound/*
!1 inbound/README.md
!1 inbound/Done/
1 inbound/Done/*
!1 inbound/Done/.gitkeep

# 2 harness/logs/ -- per-run logs
2 harness/logs/*.log

# 6 output/ -- generated Markdown output
6 output/*
!6 output/README.md
